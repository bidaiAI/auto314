VITE_CHAIN_ID=56
# Public self-host template. Official live endpoints and official factory values are documented in docs/OFFICIAL_PARAMETERS.md.
# Primary BSC RPC. Runtime order on web:
# 1) VITE_RPC_URL
# 2) built-in public BSC RPC (https://bsc-dataseed.binance.org)
VITE_RPC_URL=https://bsc-dataseed.binance.org
# Base web runtime order:
# 1) built-in public Base RPC (https://mainnet.base.org)
# 2) VITE_BASE_RPC_URL (for example Alchemy) as backup
VITE_BASE_RPC_URL=https://mainnet.base.org
# Replace with your deployed BSC factory if you are self-hosting a separate instance.
VITE_FACTORY_ADDRESS=0xf264DEf5f915628c57190616931bDf19df2cf225
VITE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: prefer bounded indexer API for launch lists, activity, and segmented charts.
# Current trading state, previews, claimable amounts, and cooldown checks still read from chain.
VITE_INDEXER_API_URL=https://your-indexer.example.com
# Public release default: keep the browser metadata helper off unless your deployment provides a protected upload path.
VITE_REFERENCE_METADATA_UPLOAD_ENABLED=0

# Optional static fallback if the API is unavailable.
VITE_INDEXER_SNAPSHOT_URL=/data/indexer-snapshot.json

# Base chain profile
# Replace with your deployed Base factory if you are self-hosting a separate instance.
VITE_BASE_FACTORY_ADDRESS=0x95302fb1Aa9cD62F070E512B3d415d8388742a22
VITE_BASE_INDEXER_API_URL=https://your-base-indexer.example.com
VITE_BASE_INDEXER_SNAPSHOT_URL=/data/base-indexer-snapshot.json
